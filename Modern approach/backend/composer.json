{
    "name": "pedalpal/bike-rentals",
    "description": "PedalPal Bike Rentals — PHP 8.5 backend",
    "type": "project",
    "require": {
        "php": "^8.5",
        "ext-redis": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "PedalPal\\": "src/"
        }
    },
    "scripts": {
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
